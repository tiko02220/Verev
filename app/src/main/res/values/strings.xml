    <string name="merchant_privacy_section_privacy_title">Privacy policy</string>
    <string name="merchant_privacy_section_privacy_subtitle">How customer and business data is protected</string>
    <string name="merchant_privacy_privacy_point_one">All merchant and customer records are stored locally for the MVP and protected with device-level access controls.</string>
    <string name="merchant_privacy_privacy_point_two">Sensitive account actions require authenticated access, and biometric unlock is optional per account.</string>
    <string name="merchant_privacy_privacy_point_three">Future sync can be introduced without changing the domain layer or invalidating existing local records.</string>
    <string name="merchant_privacy_section_data_title">Data usage</string>
    <string name="merchant_privacy_section_data_subtitle">What the platform stores to run loyalty operations</string>
    <string name="merchant_privacy_data_point_one">Store, staff, customer, transaction, and loyalty program records are stored offline in Room.</string>
    <string name="merchant_privacy_data_point_two">Billing and branding screens use local presentation state until payment-provider and asset-storage integration is added.</string>
    <string name="merchant_privacy_data_point_three">Analytics use aggregated local transactions so managers can operate with no network dependency.</string>
    <string name="merchant_terms_section_service_title">Service terms</string>
    <string name="merchant_terms_section_service_subtitle">Operational rules for using the merchant platform</string>
    <string name="merchant_terms_service_point_one">Merchant accounts are role-based and should only be accessed by authorized staff assigned to a store.</string>
    <string name="merchant_terms_service_point_two">Businesses are responsible for the accuracy of transaction, reward, and customer information entered into the app.</string>
    <string name="merchant_terms_service_point_three">Offline records remain on-device until a future backend synchronization feature is introduced.</string>
    <string name="merchant_terms_section_security_title">Security commitments</string>
    <string name="merchant_terms_section_security_subtitle">How account access and recovery are handled</string>
    <string name="merchant_terms_security_point_one">PIN and biometric recovery flows are separated from merchant content so locked sessions do not expose dashboard data.</string>
    <string name="merchant_terms_security_point_two">Session timeout and lock behavior are enforced in the app layer and remain consistent after backgrounding.</string>
    <string name="merchant_terms_security_point_three">Recovery flows allow password reset from login and PIN reset from the lock screen without sharing navigation state.</string>
